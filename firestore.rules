rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function isValidOrder(data) {
      return data.tableNo is string 
          && data.tableNo.size() <= 50
          && data.status is string
          && (data.status == 'pending' || data.status == 'preparing' || data.status == 'completed' || data.status == 'cancelled')
          && data.utensils is string
          && data.totalPrice is number
          && data.items is list;
    }

    // Orders Collection Rules
    match /orders/{orderId} {
      allow read: if true;
      allow create: if isValidId(orderId) && isValidOrder(request.resource.data);
      allow update: if isValidId(orderId) && isValidOrder(request.resource.data);
      allow delete: if false;
    }

    // Admin Config Rules (No OAuth required)
    match /configs/{configId} {
      allow read, write: if isValidId(configId);
    }
  }
}
